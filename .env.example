# 이 파일을 복사해 .env.local 로 만들고 실제 값을 채우세요.
# .env.local 은 .gitignore에 의해 git에 올라가지 않습니다.

# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 에서 발급
# next-auth(Auth.js) v5는 AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET 이름을 사용합니다
# (v4의 GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET과 다름 — v5는 이 이름을 인식하지 못함)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# NextAuth 세션 암호화 키. 터미널에서 `npx auth secret` 또는
# `openssl rand -base64 33` 으로 생성한 랜덤 문자열을 넣으세요.
AUTH_SECRET=

# Vercel 대시보드 > Storage > Blob 스토어 생성 후 발급되는 토큰
BLOB_READ_WRITE_TOKEN=
